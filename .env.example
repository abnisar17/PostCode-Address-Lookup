# Database
POSTGRES_PASSWORD=postgres

# Frontend (build-time — set to your public URL in production)
VITE_API_BASE_URL=http://localhost:8000

# Paths
DATA_DIR=data

# Data source URLs (original)
OSM_DOWNLOAD_URL=https://download.geofabrik.de/europe/great-britain-latest.osm.pbf
CODEPOINT_DOWNLOAD_URL=https://api.os.uk/downloads/v1/products/CodePointOpen/downloads?area=GB&format=CSV&redirect
NSPL_DOWNLOAD_URL=https://www.arcgis.com/sharing/rest/content/items/8a1d5b58df824b2e86fe07ddfdd87165/data

# Data source URLs (new — address coverage + enrichment)
LAND_REGISTRY_DOWNLOAD_URL=http://prod.publicdata.landregistry.gov.uk.s3-website-eu-west-1.amazonaws.com/pp-complete.csv
COMPANIES_HOUSE_DOWNLOAD_URL=http://download.companieshouse.gov.uk/BasicCompanyDataAsOneFile-2026-02-01.zip
FSA_API_BASE_URL=https://api.ratings.food.gov.uk
OPEN_UPRN_DOWNLOAD_URL=https://api.os.uk/downloads/v1/products/OpenUPRN/downloads?area=GB&format=CSV&redirect

# EPC Open Data (requires free registration at https://epc.opendatacommunities.org/)
EPC_API_BASE_URL=https://epc.opendatacommunities.org/api/v1
EPC_API_KEY=

# Ingestion tuning
BATCH_SIZE=2000
OSM_INDEX_TYPE=sparse_file_array

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
